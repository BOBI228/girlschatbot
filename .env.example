# Copy this file to .env and fill in your secrets

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenAI API key (create at https://platform.openai.com/)
OPENAI_API_KEY=

# Optional: model names (defaults are sensible)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Optional: system locale/timezone preferences
TZ=UTC
